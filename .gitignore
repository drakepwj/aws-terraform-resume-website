# Ignore personal Terraform variable files
shared.auto.tfvars

# Ignore Terraform working directories
.terraform/
.terraform.lock.hcl

# Ignore Terraform state files
terraform.tfstate
terraform.tfstate.backup
*.tfstate
*.tfstate.*

# Ignore Python cache (backend/app.py)
__pycache__/
*.pyc

# Ignore OS-specific junk
.DS_Store
Thumbs.db
*.swp
